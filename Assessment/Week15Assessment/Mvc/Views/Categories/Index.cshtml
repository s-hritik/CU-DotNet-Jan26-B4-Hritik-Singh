@model IEnumerable<CategoryDto>

<div class="container mt-4">
    <h2>Categories</h2>
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <img src="@item.ImageUrl" class="card-img-top" alt="@item.CategoryName" />
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@item.CategoryName</h5>
                        <a href="/Products/ByCategory/@item.CategoryId" class="btn btn-primary mt-auto">
                            View Products
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>