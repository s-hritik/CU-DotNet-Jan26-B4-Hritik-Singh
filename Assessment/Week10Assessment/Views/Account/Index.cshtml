@model IEnumerable<Week10Assessment.Models.Account>

<h2>Bank Accounts</h2>

@if (TempData["Success"] != null)
{
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div class="toast show" role="alert">
            <div class="toast-header bg-success text-white">
                <strong class="me-auto">Success</strong>
                <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body">@TempData["Success"]</div>
        </div>
    </div>
}

<div class="mb-3">
    <a asp-action="CreateTransaction" class="btn btn-success">Record New Transaction</a>
    <a asp-action="Create" class="btn btn-primary">Add New Account</a>
</div>

<table class="table">
    <thead>
        <tr>
            <th>Account Name</th>
            <th>Balance</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>@item.AccountName</td>
                <td>@item.Balance.ToString("C")</td>
            </tr>
        }
    </tbody>
</table>