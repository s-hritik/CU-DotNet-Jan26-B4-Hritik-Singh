@model IEnumerable<QuickLoan.Models.Loan>

@{
    ViewData["Title"] = "Loan Portfolio";
}

<div class="container mt-4">
    <h2>@ViewData["Title"]</h2>

    <p>
        <a asp-action="Add" class="btn btn-primary">Create New Loan</a>
    </p>

    <table class="table table-striped table-hover border">
        <thead class="table-dark">
            <tr>
                <th>@Html.DisplayNameFor(model => model.Id)</th>
                <th>@Html.DisplayNameFor(model => model.BorrowerName)</th>
                <th>Lender Name</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model) {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.BorrowerName</td>
                    <td>@item.LenderName</td>
                    <td>@item.Amount.ToString("C")</td>
                    <td>@(item.IsSettled ? "Settled" : "Pending")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                        
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;">
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?')">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>